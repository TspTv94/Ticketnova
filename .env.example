# TicketNova — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit the actual .env file to Git.

# ── Server ─────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development       # development | staging | production

# ── CORS ───────────────────────────────────────────────────────
CORS_ORIGIN=*              # In production: https://yourdomain.com

# ── Database (for MongoDB upgrade) ────────────────────────────
# MONGO_URI=mongodb://localhost:27017/ticketnova
# MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/ticketnova

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=info             # debug | info | warn | error
